{
  "manifest_version": 3,
  "name": "Specter",
  "version": "1.0.0",
  "description": "Browser network traffic analyzer and privacy auditor",
  "permissions": [
    "webRequest",
    "storage",
    "unlimitedStorage",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": ["models/model.onnx", "lib/onnxruntime-web/*.wasm"],
      "matches": ["<all_urls>"]
    }
  ]
}
